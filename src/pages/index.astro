---
import BaseLayout from "@layouts/BaseLayout.astro";
import NameBox from "@components/NameBox.astro";
import AlbumCard from "@components/AlbumCard.astro";
import PostItem from "@components/PostItem.astro";
import { Icon } from "astro-icon/components";
import { getPosts } from "@utils/posts";
import { getAlbums } from "@utils/albums";

const posts = await getPosts();
const albums = await getAlbums();
---

<BaseLayout
    title="Divya Jain"
    description="DevOps engineer and systems tinkerer. Writing about Rust, Go, emulators, agentic AI, and whatever I'm building next."
    activePage="home"
    hideHeader>
    <div>
        <div>
            <NameBox size="xl" />
            <div>
                <div>
                    <p>
                        <em>DevOps</em> at <em>Seclore</em>.
                        <br />
                        Tinkering in <em>Rust</em> & <em>Go</em>.
                        <br />
                        Exploring the world of <em>Agentic AI</em>.
                    </p>
                    <span>Always learning. Rarely done.</span>
                    <nav>
                        <a href="https://github.com/dvjn" aria-label="GitHub">
                            <Icon name="radix-icons:github-logo" />
                        </a>
                        <a href="https://linkedin.com/in/dvjn" aria-label="LinkedIn">
                            <Icon name="radix-icons:linkedin-logo" />
                        </a>
                    </nav>
                </div>
            </div>
        </div>

        <section>
            <div>
                <span>Blog</span>
                <a href="/blog">All posts</a>
            </div>

            {posts.slice(0, 3).map((post) => <PostItem post={post} />)}
        </section>

        <section>
            <div>
                <span>Gallery</span>
                <a href="/gallery">All albums</a>
            </div>
            <div>
                {albums.slice(0, 4).map((album) => <AlbumCard album={album} />)}
            </div>
        </section>
    </div>
</BaseLayout>

<style lang="scss">
    // outermost div = page grid
    div {
        // hero row
        > div:first-child {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 0;
            border-bottom: var(--border-width-lg) solid var(--border);

            // cell-right (after NameBox <a>)
            > div {
                display: flex;
                flex-direction: column;

                // cell-tagline
                > div {
                    background: var(--bg);
                    padding: 2rem;
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                    gap: 1.5rem;
                    flex: 1;

                    p {
                        font-size: 1rem;
                        color: var(--fg);
                        line-height: 1.75;

                        em {
                            font-style: normal;
                            color: var(--fg-strong);
                            font-weight: 700;
                        }
                    }

                    span {
                        font-size: 0.65rem;
                        font-weight: 700;
                        color: var(--fg-strong);
                        text-transform: uppercase;
                        letter-spacing: 0.08em;
                        border-left: var(--border-width-lg) solid var(--accent);
                        padding-left: 0.75rem;
                    }

                    nav {
                        display: flex;
                        gap: 1rem;

                        a {
                            color: var(--fg-strong);
                            text-decoration: none;
                            display: flex;
                            align-items: center;
                            transition: filter var(--duration-fast);

                            svg {
                                width: 1.25rem;
                                height: 1.25rem;
                            }

                            &:hover,
                            &:focus-visible {
                                filter: drop-shadow(
                                    var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--accent)
                                );
                            }
                        }
                    }
                }
            }
        }

        section {
            padding: 0 0 5rem;

            > div:first-child {
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                padding: var(--space-8) 1.5rem var(--space-4);
                border-bottom: var(--border-width-lg) solid var(--border);

                span {
                    font-family: var(--font-display);
                    font-size: 1.2rem;
                    letter-spacing: 0.08em;
                    text-transform: uppercase;
                    color: var(--fg-strong);
                }

                a {
                    font-size: 0.85rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.05em;
                    color: var(--fg-strong);
                    text-decoration: none;
                    transition: text-shadow var(--duration-fast);

                    &::after {
                        content: " →";
                    }

                    &:hover,
                    &:focus-visible {
                        text-shadow: var(--shadow-offset-hover) var(--shadow-offset-hover) 0 var(--accent);
                    }
                }
            }

            // albums grid
            > div:last-child {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
                gap: 1.5rem;
                margin: 1.5rem 1.5rem 0;
            }
        }
    }

    @media (max-width: 768px) {
        div > div:first-child {
            grid-template-columns: 1fr;
        }
    }
</style>
