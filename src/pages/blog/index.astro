---
import Header from "@components/Header.astro";
import PostItem from "@components/PostItem.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPosts } from "@utils/posts";

const posts = await getPosts();
---

<BaseLayout
    title="Blog — Divya Jain"
    description="Writing about things I've built, broken, or figured out — Rust, Go, emulators, DevOps, and more."
    activePage="blog">
    <Header label={`${posts.length} Posts`} title="Blog">
        <Fragment slot="subtitle">Writing about things I've built, broken, or figured out.</Fragment>
    </Header>

    <section>
        {posts.map((post) => <PostItem post={post} />)}
    </section>
</BaseLayout>

<style lang="scss">
    section {
        padding: 0 0 5rem;
    }
</style>
