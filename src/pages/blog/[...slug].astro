---
import CaptionedImage from "@components/CaptionedImage.astro";
import Chip from "@components/Chip.astro";
import Prose from "@components/Prose.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPosts, type Post } from "@utils/posts";

export async function getStaticPaths() {
    const posts = await getPosts();
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

export type Props = {
    post: Post;
};

const { post } = Astro.props as Props;
const { Content, title, description, tags, publishedOn, minutesRead, cover, coverCaption } = post;
---

<BaseLayout title={`${title} — Divya Jain`} description={description} activePage="blog">
    <article>
        <header>
            {
                tags && tags.length > 0 && (
                    <div class="post-tags">
                        {tags.map((tag: string) => (
                            <Chip label={tag} />
                        ))}
                    </div>
                )
            }
            <h1>{title}</h1>
            <div>
                <span>{publishedOn}</span>
                {minutesRead && <span>{minutesRead}</span>}
            </div>
        </header>

        {
            cover && (
                <div class="post-cover">
                    <CaptionedImage src={cover} alt={coverCaption ?? title} caption={coverCaption} />
                </div>
            )
        }

        <Prose>
            <Content />
        </Prose>
    </article>
</BaseLayout>

<style lang="scss">
    article {
        max-width: 860px;
        margin: 0 auto;
        padding: 5rem 1.5rem 6rem;

        header {
            display: block;
            background: none;
            border-bottom: var(--border-width-lg) solid var(--border);
            margin-bottom: var(--space-12);
            padding: var(--space-8) 0;

            .post-tags {
                display: flex;
                gap: 0.4rem;
                flex-wrap: wrap;
                margin-bottom: 1rem;
                padding: 0;
            }

            h1 {
                font-family: var(--font-display);
                font-size: clamp(2rem, 6vw, 3.5rem);
                color: var(--fg-strong);
                letter-spacing: 0.02em;
                line-height: 1.1;
                margin-bottom: var(--space-4);
            }

            > div:last-child {
                display: flex;
                gap: var(--space-4);
                padding: 0;
                font-family: var(--font-mono);
                font-size: 0.7rem;
                font-weight: 700;
                color: var(--fg);
                text-transform: uppercase;
                letter-spacing: 0.06em;
            }
        }

        .post-cover {
            margin-bottom: var(--space-12);
        }
    }
</style>
