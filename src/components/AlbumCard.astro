---
import { Image } from "astro:assets";
import { type Album } from "@utils/albums";

interface Props {
    album: Album;
}

const { album } = Astro.props;
const { slug, title, cover, date, location } = album;
---

<a href={`/gallery/${slug}`} class="album-card">
    <div class="album-card-image">
        <Image src={cover} alt={title} width={400} height={300} />
    </div>
    <div class="album-card-info">
        <div class="album-card-title">{title}</div>
        <div class="album-card-meta">
            <span>{date}</span>
            {location && <span>{location}</span>}
        </div>
    </div>
</a>

<style>
    .album-card {
        display: block;
        text-decoration: none;
        overflow: hidden;
        background: var(--surface);
        border: var(--border-width) solid var(--border);
        box-shadow: var(--shadow-stamp);
        transition: box-shadow var(--duration-fast);
    }

    .album-card:hover,
    .album-card:focus-visible {
        box-shadow: var(--shadow-stamp-hover);
    }

    .album-card-image {
        aspect-ratio: 4 / 3;
        overflow: hidden;
    }

    .album-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .album-card-info {
        padding: 0.75rem 1rem 1rem;
    }

    .album-card-title {
        font-family: var(--font-display);
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--fg-strong);
        margin-bottom: 0.25rem;
        line-height: 1.35;
    }

    .album-card-meta {
        display: flex;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--fg);
    }
</style>
