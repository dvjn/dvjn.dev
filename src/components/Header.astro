---
interface Props {
    label?: string;
    title: string;
}

const { label, title } = Astro.props;
---

<header>
    {label && <small>{label}</small>}
    <h1>{title}</h1>
    {
        Astro.slots.has("subtitle") && (
            <p>
                <slot name="subtitle" />
            </p>
        )
    }
</header>

<style lang="scss">
    header {
        display: block;
        padding: 7rem 1.5rem 3rem;
        border-bottom: var(--border-width-lg) solid var(--border);

        small {
            display: block;
            font-family: var(--font-ui);
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--fg);
            margin-bottom: 1.25rem;
        }

        h1 {
            font-family: var(--font-display);
            font-size: clamp(3rem, 10vw, 6rem);
            color: var(--fg-strong);
            letter-spacing: 0.02em;
            line-height: 1.1;
            margin-bottom: var(--space-6);
        }

        p {
            font-size: 0.9rem;
            color: var(--fg);
            line-height: 1.65;
            border-left: var(--border-width-lg) solid var(--accent);
            padding-left: var(--space-4);

            a {
                color: var(--accent);
                text-decoration: none;
                border-bottom: 1px solid var(--accent);
            }
        }
    }
</style>
