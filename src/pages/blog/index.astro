---
import { getCollection } from "astro:content";
import Header from "@components/Header.astro";
import PostItem from "@components/PostItem.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { differenceInMilliseconds, parse } from "date-fns";

const posts = (await getCollection("posts"))
    .filter((post) => post.data.draft !== true)
    .sort((a, b) =>
        differenceInMilliseconds(
            parse(b.data.published_on, "dd/MM/yyyy", new Date()),
            parse(a.data.published_on, "dd/MM/yyyy", new Date()),
        ),
    );
---

<BaseLayout title="Blog — Divya Jain" description="Writing about things I've built, broken, or figured out — Rust, Go, emulators, DevOps, and more." activePage="blog">
    <Header label={`${posts.length} Posts`} title="Blog">
        <Fragment slot="subtitle">Writing about things I've built, broken, or figured out.</Fragment>
    </Header>

    <section>
        {posts.map((post) => <PostItem post={post} />)}
    </section>
</BaseLayout>

<style lang="scss">
    section {
        padding: 0 0 5rem;
    }
</style>
